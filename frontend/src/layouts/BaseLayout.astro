---
// src/layouts/BaseLayout.astro
import '../styles/global.css'

interface Props {
    title: string;
    description?: string;
    center?: boolean;
}

const { title, description, center= false } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} - Álbum Familiar</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="bg-slate-100 text-slate-900 font-sans min-h-screen flex flex-col">
    
    <main class={`grow flex flex-col ${center ? 'items-center justify-center' : ''}`}>
      <slot />
    </main>

    </body>
</html>