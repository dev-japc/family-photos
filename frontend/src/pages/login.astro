---
// Lado del Servidor (Frontmatter)
// Si el usuario ya tiene una cookie de sesión válida, lo redirigimos directo al álbum
const token = Astro.cookies.get("auth_token")?.value;
if (token) {
  return Astro.redirect("/");
}

// Obtenemos la URL de la API desde el .env (se inyectará en el JS del cliente)
const publicBackendUrl = import.meta.env.PUBLIC_BACKEND_URL;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión - Álbum Familiar</title>
  </head>
  <body class="bg-slate-100 flex items-center justify-center min-h-screen font-sans">
    
    <main class="bg-white p-8 rounded-2xl shadow-md w-full max-w-md mx-4">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-slate-800">📸 Álbum Familiar</h1>
        <p class="text-slate-500 mt-2">Ingresa tus credenciales para acceder</p>
      </div>

      <div id="error-box" class="hidden bg-red-50 text-red-600 p-3 rounded-lg text-sm mb-4 border border-red-200"></div>

      <form id="login-form" class="space-y-5">
        <div>
          <label for="national_id_number" class="block text-sm font-semibold text-slate-700 mb-1">Cédula / Identificación</label>
          <input 
            type="text" 
            id="national_id_number" 
            name="national_id_number" 
            required 
            placeholder="Ej: 20646910"
            class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-slate-50"
          />
        </div>

        <div>
          <label for="password" class="block text-sm font-semibold text-slate-700 mb-1">Contraseña</label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            required 
            placeholder="••••••••"
            class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 bg-slate-50"
          />
        </div>

        <button 
          type="submit" 
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 rounded-lg transition-colors duration-200 shadow-sm"
        >
          Entrar al Álbum
        </button>
      </form>

      <div class="text-center mt-6 text-sm text-slate-600">
        ¿Eres nuevo en la familia? <a href="/register" class="text-blue-600 hover:underline font-medium">Regístrate aquí</a>
      </div>
    </main>

    <script define:vars={{ publicBackendUrl }}>
      const form = document.getElementById('login-form');
      const errorBox = document.getElementById('error-box');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorBox.classList.add('hidden');
        errorBox.innerText = '';

        const formData = new FormData(form);
        const data = Object.fromEntries(formData);

        try {
          // 1. Enviamos los datos directamente al backend de Go
          const response = await fetch(`${publicBackendUrl}/api/auth/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });

          const result = await response.json();

          if (!response.ok) {
            throw new Error(result.error || 'Error al iniciar sesión');
          }

          // 2. Si el login es exitoso, guardamos el token en una cookie desde el cliente
          // Ponemos 'max-age=86400' para que expire en 24 horas (ajústalo según tu JWT en Go)
          document.cookie = `auth_token=${result.token}; path=/; max-age=86400; SameSite=Lax`;

          // 3. Redirigimos al inicio (Álbum de fotos)
          window.location.href = '/';

        } catch (err) {
          errorBox.innerText = err.message;
          errorBox.classList.remove('hidden');
        }
      });
    </script>

  </body>
</html>

<style>
  @import url('https://unpkg.com/tailwindcss@^2/dist/tailwind.min.css');
</style>