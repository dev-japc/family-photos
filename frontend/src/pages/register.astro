---
// src/pages/register.astro
const token = Astro.cookies.get("auth_token")?.value;

// Si ya está logueado, no tiene sentido que se registre, lo mandamos al Home
if (token) {
  return Astro.redirect("/");
}

const publicBackendUrl = import.meta.env.PUBLIC_BACKEND_URL;
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro - Álbum Familiar</title>
</head>
<body class="bg-slate-100 flex items-center justify-center min-h-screen font-sans">

    <main class="bg-white p-8 rounded-2xl shadow-md w-full max-w-md mx-4">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-slate-800">📸 Registro Familiar</h1>
            <p class="text-slate-500 mt-2">Crea tu cuenta para acceder al álbum privado</p>
        </div>

        <div id="error-alert" class="hidden bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl mb-4 text-sm text-center">
        </div>

        <form id="register-form" class="space-y-5">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Nombre Completo</label>
                <input type="text" name="name" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-slate-800" placeholder="Ej. Juan Pérez" />
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Cédula / Identificación</label>
                <input type="text" name="national_id" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-slate-800" placeholder="Ej. 20646910" />
            </div>

            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Contraseña</label>
                <input type="password" name="password" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-slate-800" placeholder="••••••••••••" />
            </div>

            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition-colors shadow-lg shadow-blue-600/20">
                Registrarse
            </button>
        </form>

        <div class="text-center mt-6 text-sm text-slate-600">
            ¿Ya tienes una cuenta? <a href="/login" class="text-blue-600 hover:underline font-medium">Inicia sesión aquí</a>
        </div>
    </main>

    <script define:vars={{ publicBackendUrl }} is:inline>
        const form = document.getElementById('register-form');
        const errorAlert = document.getElementById('error-alert');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            errorAlert.classList.add('hidden');

            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());

            try {
                // Consumimos el endpoint de registro del backend
                const response = await fetch(`${publicBackendUrl}/api/auth/register`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        name: data.name,
                        national_id_number: data.national_id,
                        password: data.password
                    }),
                });

                const result = await response.json();

                if (!response.ok) {
                    // Si el backend responde 403 o similar porque no está en la whitelist
                    throw new Error(result.error || 'Error al registrar el usuario');
                }

                window.location.href = '/login?registered=true';

            } catch (error) {
                errorAlert.textContent = error.message;
                errorAlert.classList.remove('hidden');
            }
        });
    </script>
</body>
</html>

<style>
  @import url('https://unpkg.com/tailwindcss@^2/dist/tailwind.min.css');
</style>