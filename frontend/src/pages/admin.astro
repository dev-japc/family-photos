---
// src/pages/admin.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '@components/footer.astro'
// @ts-ignore
import { jwtDecode } from 'jwt-decode';

const token = Astro.cookies.get("auth_token")?.value;

// if there's no token, redirect to login page
if (!token) {
  return Astro.redirect("/login");
}

// Decoding the token to check if the user is admin
try {
  const decoded: any = jwtDecode(token);
  const isAdmin = decoded.is_admin === true || decoded.role === 'admin';
  if (!isAdmin) {
    return Astro.redirect("/");
  }
} catch (error) {
  return Astro.redirect("/logout");
}

const publicBackendUrl = import.meta.env.PUBLIC_BACKEND_URL;
---

<BaseLayout title="Panel de Administración">
  <nav class="w-full bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between shadow-sm">
    <div class="flex items-center gap-2">
      <span class="text-2xl">⚙️</span>
      <span class="text-xl font-bold text-slate-800 tracking-tight">Panel de Control</span>
    </div>
    <a href="/" class="text-sm font-medium text-blue-600 hover:underline">
      Volver al Álbum
    </a>
  </nav>

  <div class="max-w-xl w-full mx-auto px-4 py-8 grow">
    <div class="mb-8">
      <h2 class="text-2xl font-bold text-center text-slate-800">Lista Blanca de Acceso</h2>
      <p class="text-slate-500 text-center text-sm mt-1">Sólo las personas cuyas cédulas estén aquí registradas podrán crearse una cuenta en el sistema y ver las fotos.</p>
    </div>

    <div class="grid grid-cols-1 w-full mx-auto md:grid-cols-2 gap-6">
      <div class="bg-white  w-52 mx-auto p-3 rounded-2xl shadow-sm border border-slate-200 h-fit">
        <h3 class="font-bold text-center text-slate-800 mb-4">Autorizar Familiar</h3>
        <form id="whitelist-form" class="space-y-4">
          <div>
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Número de Cédula</label>
            <input type="text" name="national_id" required class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm text-slate-800" placeholder="Ej. 22333555" />
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Nombre Completo</label>
            <input type="text" name="name" required class="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm text-slate-800" placeholder="Ej. Juan Pérez" />
          </div>
          <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 rounded-xl text-sm transition-colors shadow-md shadow-blue-600/10">
            Agregar a Lista
          </button>
        </form>
      </div>

      <div class="md:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 bg-slate-50">
          <h3 class="font-bold text-slate-800 text-sm text-center">Cédulas con Acceso Permitido</h3>
        </div>
        <div class="flex justify-between px-6 py-2.5 bg-slate-100 border-b border-slate-100 text-xs text-slate-500 tracking-wider">
            <span>Cédula</span>
            <span>Nombre</span>
            <span class="text-right">Acción</span>
        </div>
        <ul id="whitelist-container" class="divide-y divide-slate-100 py-4 overflow-y-auto">
          <li class="px-6 py-4 text-center text-sm text-slate-400">Cargando lista blanca...</li>
        </ul>
      </div>
    </div>
  </div>

  <script define:vars={{ publicBackendUrl, token }} is:inline>
    const container = document.getElementById('whitelist-container');
    const form = document.getElementById('whitelist-form');

    // Function to fetch and display the whitelist
    async function fetchWhitelist() {
      try {
        const response = await fetch(`${publicBackendUrl}/api/admin/whitelist`, {
          method: 'GET',
          headers: {
            'Authorization': `Bearer ${token}`
          }
        });

        if (!response.ok) throw new Error('No se pudo cargar la lista blanca');
        
        const data = await response.json();
        
        if (!data || data.length === 0) {
          container.innerHTML = `<li class="px-6 py-8 text-center text-sm text-slate-400">No hay cédulas registradas en la lista blanca aún.</li>`;
          return;
        }

        container.innerHTML = data.map(item => `
            <li class="flex justify-between items-center gap-4 px-6 py-3.5 items-center hover:bg-slate-50 transition-colors">
                <span class="font-mono text-sm text-slate-700 font-medium">${item.national_id_number}</span>
                
                <span class="text-sm text-slate-600 truncate bg-transparent" title="${item.name || 'Sin nombre'}">
                ${item.name || 'Sin nombre'}
                </span>
                
                <div class="text-right">
                <button 
                    data-id="${item.national_id_number}" 
                    class="delete-btn text-xs font-semibold text-red-500 hover:text-red-700 bg-red-500 hover:bg-red-100 px-3 py-1.5 rounded-lg transition-all"
                >
                    Revocar
                </button>
                </div>
            </li>
        `).join('');

        // Attach event listeners to delete buttons
        document.querySelectorAll('.delete-btn').forEach(btn => {
          btn.addEventListener('click', () => deleteFromWhitelist(btn.dataset.id));
        });

      } catch (error) {
        container.innerHTML = `<li class="px-6 py-8 text-center text-sm text-red-500 font-medium">⚠️ Error: ${error.message}</li>`;
      }
    }

    // Function to add a national ID
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const idNumber = formData.get('national_id');
      const name = formData.get('name');

      try {
        const response = await fetch(`${publicBackendUrl}/api/admin/whitelist`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ national_id_number: idNumber , name: name })
        });

        if (!response.ok) throw new Error('Error al añadir la cédula');

        form.reset();
        fetchWhitelist(); // Refresh the list automatically after addition
      } catch (error) {
        alert(error.message);
      }
    });

    // Function to delete fro the whitelist
    async function deleteFromWhitelist(idNumber) {
      if (!confirm(`¿Estás seguro de que deseas revocar el acceso a la cédula ${idNumber}?`)) return;

      try {
        const response = await fetch(`${publicBackendUrl}/api/admin/whitelist/${idNumber}`, {
          method: 'DELETE',
          headers: {
            'Authorization': `Bearer ${token}`
          }
        });

        if (!response.ok) throw new Error('No se pudo eliminar la cédula');

        fetchWhitelist(); // Refresh the list automatically after deletion
      } catch (error) {
        alert(error.message);
      }
    }

    // Initial fetch of the whitelist when the page loads
    fetchWhitelist();
  </script>
  <Footer />
</BaseLayout>