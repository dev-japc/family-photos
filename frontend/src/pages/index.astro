---
// src/pages/index.astro
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Family Photos - Álbum Familiar Digital</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="glow-bg"></div>
    <div class="glow-bg-secondary"></div>

    <header class="app-header">
      <div class="logo">
        <span class="serif">Nuestras</span>Memorias
      </div>
      <nav class="nav-links">
        <a href="#galeria" class="active">Galería</a>
        <a href="#subir">Subir Foto</a>
      </nav>
    </header>

    <main class="container">
      <section class="hero">
        <h1 class="hero-title">Preservando cada instante, <span class="accent-text">juntos.</span></h1>
        <p class="hero-description">
          Un espacio privado y seguro para compartir los momentos más preciados de nuestra familia. Sube fotos, añade recuerdos y revive cada risa.
        </p>
        <div class="hero-actions">
          <a href="#galeria" class="btn btn-primary">Ver Álbum</a>
          <a href="#subir" class="btn btn-secondary">Añadir Foto</a>
        </div>
      </section>

      <section id="galeria" class="gallery-section">
        <div class="section-header">
          <h2>Galería de Recuerdos</h2>
          <p>Los momentos más recientes añadidos por la familia.</p>
        </div>

        <div class="gallery-grid" id="photos-grid">
          <!-- Placeholder cards that look absolutely premium with CSS loading states -->
          <div class="photo-card animate-in">
            <div class="photo-wrapper">
              <div class="photo-placeholder warm-grad-1"></div>
              <div class="photo-overlay">
                <span class="photo-date">Hace 2 días</span>
              </div>
            </div>
            <div class="photo-info">
              <h3>Domingo en el parque</h3>
              <p>Subido por Mamá</p>
            </div>
          </div>

          <div class="photo-card animate-in" style="animation-delay: 0.1s;">
            <div class="photo-wrapper">
              <div class="photo-placeholder warm-grad-2"></div>
              <div class="photo-overlay">
                <span class="photo-date">Semana pasada</span>
              </div>
            </div>
            <div class="photo-info">
              <h3>Cumpleaños de Sofía</h3>
              <p>Subido por Tío Carlos</p>
            </div>
          </div>

          <div class="photo-card animate-in" style="animation-delay: 0.2s;">
            <div class="photo-wrapper">
              <div class="photo-placeholder warm-grad-3"></div>
              <div class="photo-overlay">
                <span class="photo-date">Hace 2 semanas</span>
              </div>
            </div>
            <div class="photo-info">
              <h3>Cena familiar navideña</h3>
              <p>Subido por Abuelo</p>
            </div>
          </div>
        </div>
      </section>

      <section id="subir" class="upload-section">
        <div class="upload-container">
          <div class="upload-info">
            <h2>Comparte una nueva memoria</h2>
            <p>Elige una imagen y añade un pequeño comentario o título para que todos sepamos cuándo y dónde fue tomado.</p>
            <div class="upload-stats">
              <div class="stat-item">
                <span class="stat-num">3</span>
                <span class="stat-label">Álbumes</span>
              </div>
              <div class="stat-item">
                <span class="stat-num">124</span>
                <span class="stat-label">Fotos</span>
              </div>
            </div>
          </div>
          
          <div class="upload-card">
            <form id="upload-form" class="glass-form">
              <div class="form-group file-group">
                <label for="file-input" class="dropzone">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-upload-cloud"><polyline points="16 16 12 12 8 16"></polyline><line x1="12" y1="12" x2="12" y2="21"></line><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"></path><polyline points="16 16 12 12 8 16"></polyline></svg>
                  <span>Arrastra tu foto o haz clic para buscar</span>
                  <span class="file-hint">Formatos aceptados: JPG, PNG, WEBP</span>
                </label>
                <input type="file" id="file-input" accept="image/*" required />
              </div>

              <div class="form-group">
                <label for="title-input">Título de la foto</label>
                <input type="text" id="title-input" placeholder="Ej. Vacaciones de Verano" required />
              </div>

              <div class="form-group">
                <label for="desc-input">Descripción / Recuerdo</label>
                <textarea id="desc-input" rows="3" placeholder="Cuéntanos un poco sobre este momento..." required></textarea>
              </div>

              <button type="submit" class="btn btn-primary btn-block">Publicar en el Álbum</button>
            </form>
          </div>
        </div>
      </section>
    </main>

    <footer class="app-footer">
      <p>&copy; {new Date().getFullYear()} Nuestras Memorias - Álbum Familiar Privado</p>
    </footer>

    <script>
      // Client-side logic can be added here
      console.log('¡Hola de Nuestras Memorias!');
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg-primary: #0a0c10;
    --bg-secondary: #12151c;
    --text-primary: #f3f4f6;
    --text-secondary: #9ca3af;
    --accent: #d97706; /* warm amber */
    --accent-light: #f59e0b;
    --accent-glow: rgba(217, 119, 6, 0.15);
    --glass-bg: rgba(18, 21, 28, 0.6);
    --glass-border: rgba(255, 255, 255, 0.06);
    --font-sans: 'Outfit', sans-serif;
    --font-serif: 'Playfair Display', serif;
    --border-radius: 16px;
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-sans);
    line-height: 1.6;
    overflow-x: hidden;
    position: relative;
    min-height: 100vh;
  }

  /* Decorative glows */
  .glow-bg {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(217, 119, 6, 0.08) 0%, rgba(0,0,0,0) 70%);
    top: -200px;
    right: -100px;
    z-index: -1;
    pointer-events: none;
  }

  .glow-bg-secondary {
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.05) 0%, rgba(0,0,0,0) 70%);
    bottom: 100px;
    left: -200px;
    z-index: -1;
    pointer-events: none;
  }

  /* Typography helper */
  .serif {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
  }

  .accent-text {
    background: linear-gradient(135deg, var(--accent-light), #ec4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Header */
  .app-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 8%;
    position: sticky;
    top: 0;
    background-color: rgba(10, 12, 16, 0.8);
    backdrop-filter: blur(12px);
    z-index: 100;
    border-bottom: 1px solid var(--glass-border);
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .logo span {
    margin-right: 6px;
    color: var(--accent-light);
  }

  .nav-links a {
    color: var(--text-secondary);
    text-decoration: none;
    margin-left: 24px;
    font-weight: 500;
    transition: var(--transition);
    position: relative;
    padding: 4px 0;
  }

  .nav-links a:hover, .nav-links a.active {
    color: var(--text-primary);
  }

  .nav-links a.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--accent);
    border-radius: 2px;
  }

  /* Container */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero Section */
  .hero {
    padding: 100px 0 80px;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 24px;
  }

  .hero-description {
    font-size: 1.2rem;
    color: var(--text-secondary);
    margin-bottom: 40px;
    font-weight: 300;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 16px;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 28px;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--border-radius);
    text-decoration: none;
    transition: var(--transition);
    cursor: pointer;
  }

  .btn-primary {
    background-color: var(--accent);
    color: #ffffff;
    border: none;
    box-shadow: 0 4px 14px rgba(217, 119, 6, 0.3);
  }

  .btn-primary:hover {
    background-color: var(--accent-light);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(217, 119, 6, 0.4);
  }

  .btn-secondary {
    background-color: var(--glass-bg);
    color: var(--text-primary);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(8px);
  }

  .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
  }

  .btn-block {
    display: flex;
    width: 100%;
  }

  /* Gallery Section */
  .gallery-section {
    padding: 80px 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-header h2 {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-weight: 400;
    margin-bottom: 8px;
  }

  .section-header p {
    color: var(--text-secondary);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 32px;
  }

  .photo-card {
    background-color: var(--bg-secondary);
    border-radius: var(--border-radius);
    overflow: hidden;
    border: 1px solid var(--glass-border);
    transition: var(--transition);
  }

  .photo-card:hover {
    transform: translateY(-6px);
    border-color: rgba(217, 119, 6, 0.3);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
  }

  .photo-wrapper {
    position: relative;
    width: 100%;
    height: 240px;
    overflow: hidden;
  }

  .photo-placeholder {
    width: 100%;
    height: 100%;
    transition: var(--transition);
  }

  .warm-grad-1 {
    background: linear-gradient(135deg, #1e1b4b, #311005);
  }
  .warm-grad-2 {
    background: linear-gradient(135deg, #022c22, #1c1917);
  }
  .warm-grad-3 {
    background: linear-gradient(135deg, #1c1917, #3b0764);
  }

  .photo-card:hover .photo-placeholder {
    transform: scale(1.05);
  }

  .photo-overlay {
    position: absolute;
    bottom: 16px;
    left: 16px;
  }

  .photo-date {
    background-color: rgba(10, 12, 16, 0.7);
    backdrop-filter: blur(6px);
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 0.8rem;
    color: var(--text-primary);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .photo-info {
    padding: 20px;
  }

  .photo-info h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .photo-info p {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  /* Upload Section */
  .upload-section {
    padding: 80px 0 120px;
  }

  .upload-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    background: linear-gradient(135deg, rgba(18, 21, 28, 0.4) 0%, rgba(10, 12, 16, 0.4) 100%);
    border-radius: 24px;
    padding: 48px;
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(8px);
  }

  .upload-info h2 {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-weight: 400;
    margin-bottom: 16px;
  }

  .upload-info p {
    color: var(--text-secondary);
    margin-bottom: 32px;
  }

  .upload-stats {
    display: flex;
    gap: 40px;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
  }

  .stat-num {
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent-light);
  }

  .stat-label {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .upload-card {
    width: 100%;
  }

  .glass-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .form-group input[type="text"],
  .form-group textarea {
    background-color: rgba(10, 12, 16, 0.5);
    border: 1px solid var(--glass-border);
    border-radius: var(--border-radius);
    padding: 12px 16px;
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 1rem;
    transition: var(--transition);
  }

  .form-group input[type="text"]:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }

  .file-group input[type="file"] {
    display: none;
  }

  .dropzone {
    border: 2px dashed var(--glass-border);
    border-radius: var(--border-radius);
    padding: 40px 20px;
    text-align: center;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    background-color: rgba(10, 12, 16, 0.2);
    transition: var(--transition);
  }

  .dropzone:hover {
    border-color: var(--accent);
    background-color: rgba(217, 119, 6, 0.02);
  }

  .dropzone svg {
    color: var(--text-secondary);
    transition: var(--transition);
  }

  .dropzone:hover svg {
    color: var(--accent-light);
    transform: translateY(-4px);
  }

  .file-hint {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  /* Footer */
  .app-footer {
    text-align: center;
    padding: 40px 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
    border-top: 1px solid var(--glass-border);
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-in {
    animation: fadeInUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  /* Responsive Design */
  @media (max-width: 968px) {
    .upload-container {
      grid-template-columns: 1fr;
      padding: 32px;
      gap: 40px;
    }

    .hero-title {
      font-size: 2.8rem;
    }
  }

  @media (max-width: 640px) {
    .app-header {
      padding: 20px 24px;
      flex-direction: column;
      gap: 16px;
    }

    .nav-links a {
      margin: 0 12px;
    }

    .hero-title {
      font-size: 2.2rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }
  }
</style>
